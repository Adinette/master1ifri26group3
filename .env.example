# =====================================================================
# SFMC Bénin — Fichier d'exemple de configuration
# Copier ce fichier en `.env` à la racine du projet, puis adapter les
# valeurs ci-dessous.  Ce fichier est versionné, le `.env` réel ne l'est PAS.
# =====================================================================

# ---------------------------------------------------------------------
# Base de données PostgreSQL (OBLIGATOIRE)
# ---------------------------------------------------------------------
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Une seule base est partagée par tous les microservices.
# Le `docker-compose.yml` ne lance PAS Postgres pour l'application :
# il faut soit un Postgres local installé, soit un service hébergé
# (Neon, Supabase, etc.).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/sfmc"

# ---------------------------------------------------------------------
# NextAuth (session + JWT)
# ---------------------------------------------------------------------
# En production, générer une clé aléatoire forte (ex : `openssl rand -base64 32`).
NEXTAUTH_SECRET="changez-cette-cle-en-production"
NEXTAUTH_URL="http://localhost:3000"

# Clé JWT utilisée par le micro-service Auth (peut être identique à NEXTAUTH_SECRET).
JWT_SECRET="changez-cette-cle-en-production"

# Active le provider "Credentials" (login email + mot de passe).
# Mettre à `false` pour ne garder que Google OAuth.
ENABLE_CREDENTIALS_PROVIDER=true

# ---------------------------------------------------------------------
# Google OAuth (optionnel — laisser vide si non utilisé)
# ---------------------------------------------------------------------
# Créer des credentials sur https://console.cloud.google.com/apis/credentials
# puis renseigner ici. Sinon, le bouton "Se connecter avec Google" sera inactif.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URL="http://localhost:3000/api/auth/callback/google"

# ---------------------------------------------------------------------
# RabbitMQ (défaut OK si l'on utilise `npm run dev:infra`)
# ---------------------------------------------------------------------
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# ---------------------------------------------------------------------
# URLs des microservices (défauts OK en local)
# ---------------------------------------------------------------------
AUTH_SERVICE_URL="http://localhost:3001"
USER_SERVICE_URL="http://localhost:3002"
PRODUCT_SERVICE_URL="http://localhost:3003"
INVENTORY_SERVICE_URL="http://localhost:3004"
ORDER_SERVICE_URL="http://localhost:3005"
PRODUCTION_SERVICE_URL="http://localhost:3006"
BILLING_SERVICE_URL="http://localhost:3007"
NOTIFICATION_SERVICE_URL="http://localhost:3008"
REPORTING_SERVICE_URL="http://localhost:3009"

# ---------------------------------------------------------------------
# Kong (défaut OK)
# ---------------------------------------------------------------------
KONG_ADMIN_URL="http://localhost:8001"
